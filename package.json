-------------------- app/auth/signin/page.tsx --------------------
import { getCsrfToken, signIn } from "next-auth/react";
import { useSearchParams } from "next/navigation";
import React, { useState } from "react";

export default function SignInPage() {
  const params = useSearchParams();
  const callbackUrl = params.get("callbackUrl") || "/";
  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [loading, setLoading] = useState(false);

  async function handleSubmit(e: React.FormEvent) {
    e.preventDefault();
    setLoading(true);
    await signIn("credentials", { email, password, callbackUrl });
    setLoading(false);
  }

  return (
    <div className="max-w-md mx-auto mt-20 bg-gray-800 p-6 rounded">
      <h2 className="text-xl mb-4">Sign in</h2>
      <form onSubmit={handleSubmit} className="space-y-4">
        <input value={email} onChange={(e) => setEmail(e.target.value)} placeholder="Email" className="w-full p-2 rounded bg-gray-700" />
        <input type="password" value={password} onChange={(e) => setPassword(e.target.value)} placeholder="Password" className="w-full p-2 rounded bg-gray-700" />
        <button disabled={loading} className="w-full bg-indigo-600 p-2 rounded">{loading ? "Signing in..." : "Sign in"}</button>
      </form>
    </div>
  );
}

-------------------- components/Editor.tsx --------------------
import React, { useRef, useState } from "react";

export default function Editor() {
  const fileInputRef = useRef<HTMLInputElement | null>(null);
  const [files, setFiles] = useState<File[]>([]);
  const [prompt, setPrompt] = useState("");
  const [generating, setGenerating] = useState(false);
  const [message, setMessage] = useState<string | null>(null);

  function handleFiles(e: React.ChangeEvent<HTMLInputElement>) {
    if (!e.target.files) return;
    setFiles((f) => [...f, ...Array.from(e.target.files || [])]);
  }

  async function generateVideo() {
    if (!prompt) return setMessage("Enter a prompt first");
    setGenerating(true);
    setMessage(null);
    try {
      const res = await fetch("/api/replicate/generate", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ prompt })
      });
      const json = await res.json();
      if (json.error) setMessage(json.error);
      else setMessage("Generation submitted — check Replicate dashboard or follow returned prediction id.");
    } catch (e: any) {
      setMessage(e.message || String(e));
    } finally {
      setGenerating(false);
    }
  }

  return (
    <div className="grid grid-cols-3 gap-4">
      <div className="col-span-2 bg-gray-800 p-4 rounded">
        <div className="mb-4">
          <div className="h-64 bg-black rounded flex items-center justify-center text-gray-400">Preview Canvas (WIP)</div>
        </div>
        <div className="space-y-2">
          <h3 className="font-semibold">Assets</h3>
          <div>
            <input ref={fileInputRef} type="file" multiple onChange={handleFiles} />
            <div className="mt-2">
              {files.map((f, i) => (
                <div key={i} className="text-sm">{f.name} ({Math.round(f.size / 1024)} KB)</div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <aside className="bg-gray-800 p-4 rounded">
        <h3 className="font-semibold mb-2">AI Text → Video</h3>
        <textarea value={prompt} onChange={(e) => setPrompt(e.target.value)} placeholder="Enter a text prompt" className="w-full h-28 p-2 rounded bg-gray-700 mb-2" />
        <button onClick={generateVideo} className="w-full bg-green-600 p-2 rounded" disabled={generating}>{generating ? "Generating..." : "Generate Video"}</button>
        {message && <div className="mt-2 text-sm">{message}</div>}

        <div className="mt-6">
          <h4 className="font-semibold">Export</h4>
          <p className="text-sm text-gray-400">Export to MP4 using in-browser ffmpeg (may be slow in large projects).</p>
          <button className="mt-2 w-full bg-indigo-600 p-2 rounded" onClick={() => alert('Export not yet implemented in this MVP')}>Export MP4</button>
        </div>
      </aside>
    </div>
  );
}

-------------------- utils/ffmpeg.ts --------------------
import { createFFmpeg, fetchFile } from "@ffmpeg/ffmpeg";

export async function exportToMp4(file: File) {
  const ffmpeg = createFFmpeg({ log: true });
  await ffmpeg.load();
  ffmpeg.FS("writeFile", file.name, await fetchFile(file));
  // Example: just copy the input into an MP4 container (works for some formats)
  const outputName = "output.mp4";
  await ffmpeg.run("-i", file.name, "-c:v", "libx264", "-preset", "fast", "-pix_fmt", "yuv420p", outputName);
  const data = ffmpeg.FS("readFile", outputName);
  const url = URL.createObjectURL(new Blob([data.buffer], { type: "video/mp4" }));
  return url;
}

-------------------- README.md --------------------
# AI Video Editor — MVP

This repository is a starter MVP for a browser-based AI video editor (Next.js + TypeScript) with:

- NextAuth (Credentials) + Prisma (SQLite) for authentication
- Text → Video integration using Replicate (serverless API route proxy)
- Basic editor UI: asset import, canvas preview placeholder, timeline/exports stub
- In-browser MP4 export using @ffmpeg/ffmpeg (ffmpeg.wasm)

Important: Secrets are NOT committed. You must add the following environment variables to Vercel (or .env.local for local development):

- REPLICATE_API_TOKEN — your Replicate API key
- NEXTAUTH_SECRET — a long random string (eg `openssl rand -hex 32`)
- NEXTAUTH_URL — your site URL (eg https://your-site.vercel.app)
- DATABASE_URL — optional (defaults to SQLite `file:./dev.db`)
- SEED_EMAIL, SEED_PASSWORD — used to seed a demo user locally (optional)

Quick local setup

1. Install dependencies:

   npm install

2. Generate Prisma client and run migration:

   npx prisma generate
   npx prisma migrate dev --name init

3. Seed a demo user (locally):

   export SEED_EMAIL=your-email@example.com
   export SEED_PASSWORD=yourpassword
   npx ts-node prisma/seed.ts

4. Start dev server

   npm run dev

Vercel deployment

- Create a Vercel project and connect this repository.
- Add the required environment variables in Vercel settings: REPLICATE_API_TOKEN, NEXTAUTH_SECRET, NEXTAUTH_URL
- Deploy. If you use an external DB in production, set DATABASE_URL.

Notes

- The Replicate API route is a simple proxy: app/api/replicate/generate/route.ts. The example uses a generic POST to /v1/predictions. For production, adapt the payload/version to the exact Replicate model you want to use.
- FFmpeg in the browser is heavy; consider server-side rendering for large exports.
- This project is a scaffold/MVP. Many features (real timeline editing, keyframes, layer compositing, asset storage, robust export, progress tracking) are intentionally left as next steps.

Security

- Do not commit API keys. Use Vercel environment variables.

